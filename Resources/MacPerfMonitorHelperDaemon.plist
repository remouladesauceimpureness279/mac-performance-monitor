<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The launchd label. Must match the plist filename (minus .plist) and the
	     name passed to SMAppService.daemon(plistName:). -->
	<key>Label</key>
	<string>uk.co.bzwrd.macperfmonitor.helper</string>

	<!-- The helper executable, as a path relative to the .app bundle root.
	     Scripts/bundle.sh copies the MacPerfMonitorHelper binary here. -->
	<key>BundleProgram</key>
	<string>Contents/MacOS/MacPerfMonitorHelper</string>

	<!-- Demand-launched: launchd starts the daemon when the app first connects
	     to this Mach service, and lets it idle-exit afterwards. No RunAtLoad or
	     KeepAlive, so it costs nothing until coverage is actually used. -->
	<key>MachServices</key>
	<dict>
		<key>uk.co.bzwrd.macperfmonitor.helper</key>
		<true/>
	</dict>

	<!-- Associates the daemon with the app in System Settings > Login Items, so
	     the user sees and approves it as MacPerfMonitor's helper. -->
	<key>AssociatedBundleIdentifiers</key>
	<array>
		<string>uk.co.bzwrd.macperfmonitor</string>
	</array>
</dict>
</plist>
