<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  MacPerfMonitor is not sandboxed: it reads process and memory data directly via
	  libproc and Mach, which the App Sandbox would block. Hardened Runtime is
	  enabled at signing time (the codesign runtime option) for notarisation; it
	  needs no extra exceptions for the user-level reads.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
